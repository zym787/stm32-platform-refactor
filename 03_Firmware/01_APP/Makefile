-I01_APP/User_Task_Config/inc \
-I01_APP/User_Isr_handlers/inc \
-I01_APP/User_Sensor/mpu6050/inc

# 01_SERVICE — business-agnostic services (OTA, storage facade, future FOTA/etc)
C_INCLUDES_SERVICE = \
-I01_SERVICE/service_storage/inc \
-I01_SERVICE/service_ota/inc

# 03_Config
C_INCLUDES_CFG = \
-I03_Config/inc

C_INCLUDES = \
-ICore/Inc \
-IDrivers/STM32F4xx_HAL_Driver/Inc \
-IDrivers/STM32F4xx_HAL_Driver/Inc/Legacy \
-IMiddlewares/Third_Party/FreeRTOS/Source/include \
-IMiddlewares/Third_Party/FreeRTOS/Source/CMSIS_RTOS_V2 \
-IMiddlewares/Third_Party/FreeRTOS/Source/portable/GCC/ARM_CM4F \
-IDrivers/CMSIS/Device/ST/STM32F4xx/Include \
-IDrivers/CMSIS/Include \
$(C_INCLUDES_MCU) \
$(C_INCLUDES_BSP_DRV) \
$(C_INCLUDES_BSP_INT) \
$(C_INCLUDES_BSP_IF) \
$(C_INCLUDES_OSAL) \
$(C_INCLUDES_MW) \
$(C_INCLUDES_DBG) \
$(C_INCLUDES_APP) \
$(C_INCLUDES_SERVICE) \
$(C_INCLUDES_CFG)


# AS includes
AS_INCLUDES =

CFLAGS = $(MCU) $(C_DEFS) $(C_INCLUDES) $(OPT) -Wall -fdata-sections -ffunction-sections

ifeq ($(DEBUG), 1)
CFLAGS += -g -gdwarf-2
endif

# Generate dependency information
CFLAGS += -MMD -MP -MF"$(@:%.o=%.d)"

ASFLAGS = $(MCU) $(AS_DEFS) $(AS_INCLUDES) $(OPT) -Wall -fdata-sections -ffunction-sections


#######################################
# LDFLAGS
#######################################
# link script
LDSCRIPT = STM32F411XX_FLASH.ld

# MCU memory size (STM32F411xE)
FLASH_SIZE_BYTES = 524288
RAM_SIZE_BYTES = 131072

# libraries
LIBS = -lc -lm -lnosys
LIBDIR =
LDFLAGS = $(MCU) -specs=nano.specs -T$(LDSCRIPT) $(LIBDIR) $(LIBS) -Wl,-Map=$(BUILD_DIR)/$(TARGET).map,--cref -Wl,--gc-sections -u _printf_float

# default action: build all
all: | $(BUILD_DIR)
	@cd Tools && uv run build_summary.py --make-exe "$(MAKE)" --build-dir "../$(BUILD_DIR)" --target "build-core"

build-core: $(BUILD_DIR)/$(TARGET).elf $(BUILD_DIR)/$(TARGET).hex $(BUILD_DIR)/$(TARGET).bin mem-report ota-image


#######################################
# build the application
#######################################
OBJECTS  = $(addprefix $(BUILD_DIR)/,$(notdir $(C_SOURCES:.c=.o)))
vpath %.c $(sort $(dir $(C_SOURCES)))

OBJECTS += $(addprefix $(BUILD_DIR)/,$(notdir $(ASM_SOURCES:.s=.o)))
vpath %.s $(sort $(dir $(ASM_SOURCES)))
OBJECTS += $(addprefix $(BUILD_DIR)/,$(notdir $(ASM_SOURCES_S:.S=.o)))
vpath %.S $(sort $(dir $(ASM_SOURCES_S)))

$(BUILD_DIR)/%.o: %.c Makefile | $(BUILD_DIR)
	$(CC) -c $(CFLAGS) $< -o $@

$(BUILD_DIR)/%.o: %.s Makefile | $(BUILD_DIR)
	$(AS) -c $(ASFLAGS) $< -o $@

$(BUILD_DIR)/%.o: %.S Makefile | $(BUILD_DIR)
	$(AS) -c $(CFLAGS) $< -o $@

$(BUILD_DIR)/$(TARGET).elf: $(OBJECTS) Makefile
	$(CC) $(OBJECTS) $(LDFLAGS) -o $@
	$(SZ) $@

$(BUILD_DIR)/%.hex: $(BUILD_DIR)/%.elf | $(BUILD_DIR)
	$(HEX) $< $@

$(BUILD_DIR)/%.bin: $(BUILD_DIR)/%.elf | $(BUILD_DIR)
	$(BIN) $< $@

$(BUILD_DIR):
	mkdir $@

#######################################
# memory report
#######################################
# MEM_REPORT_FAIL_ABOVE: optional fraction in [0, 1] (e.g. 0.95). When set, any
# linker MEMORY region above this usage fraction causes mem-report (and thus the
# build) to fail. Leave empty to keep mem-report informational.
MEM_REPORT_FAIL_ABOVE ?=
ifneq ($(strip $(MEM_REPORT_FAIL_ABOVE)),)
MEM_REPORT_EXTRA_ARGS := --fail-above $(MEM_REPORT_FAIL_ABOVE)
else
MEM_REPORT_EXTRA_ARGS :=
endif

mem-report: $(BUILD_DIR)/$(TARGET).elf $(BUILD_DIR)/$(TARGET).hex $(BUILD_DIR)/$(TARGET).bin
	@cd Tools && uv run mem_report.py --elf "../$(BUILD_DIR)/$(TARGET).elf" --ld "../$(LDSCRIPT)" --size-tool "$(SZ)" $(MEM_REPORT_EXTRA_ARGS)

#######################################
# OTA image packaging
#######################################
# Wraps the raw .bin with a 16 B header (12 zero bytes + 4 B LE app_size)
# then AES-256-CBC encrypts with the hardcoded key/iv that bootmanager.c's
# exA_to_exB_AES expects. Output: $(BUILD_DIR)/$(TARGET).mxxx — Ymodem this
# to the listener after sending the 0x11 22 33 magic.
#
# Uses the same `uv run` virtualenv as mem-report — pycryptodome is pinned
# in Tools/pyproject.toml so uv auto-resolves it on first run, no manual
# `pip install` needed.
ota-image: $(BUILD_DIR)/$(TARGET).bin
	@cd Tools && uv run ota_encrypt.py "../$(BUILD_DIR)/$(TARGET).bin" "../$(BUILD_DIR)/$(TARGET).mxxx"

#######################################
# external flash assets (LVGL sub-region)
#######################################
# Standalone targets — not pulled in by `all`, since the firmware self-bootstrap
# already provisions sprites from .rodata on first boot.  These targets exist so
# image-only updates can skip the full firmware rebuild + reflash:
#
#   make pack-assets   →  $(BUILD_DIR)/assets.bin (just the binary)
#   make flash-assets  →  pack + program W25Q64 LVGL partition via JFlash + .FLM
#
# JLink address 0x90000000 is remapped by the custom W25Q64_8M_FLM.FLM to
# W25Q64 byte offset 0x300000 (LVGL partition start).  Requires
# %APPDATA%/SEGGER/JLinkDevices/ST/STM32F4/{Devices.xml,W25Q64_8M_FLM.FLM} to
# be in place (Phase 2 setup).
ASSETS_BIN     := $(BUILD_DIR)/assets.bin
ASSETS_CFG     := 03_Config/inc/cfg_storage.h
ASSETS_LV_CONF := 02_Middleware_Platform/lv-gl/lvgl/lv_conf.h
ASSETS_DIR     := 02_Middleware_Platform/lv-gl/lvgl_ui/images
ASSETS_SRCS    := $(ASSETS_DIR)/_fen_alpha_70x5.c \
                  $(ASSETS_DIR)/_miao_alpha_70x5.c \
                  $(ASSETS_DIR)/_time_alpha_40x5.c \
                  $(ASSETS_DIR)/_biaopan1_alpha_240x240.c
JFLASH_PRJ     := Tools/segger/jflash/411_w25q64.jflash
# Absolute path is used because SEGGER's installer doesn't add JFlash.exe to
# Windows PATH.  Override with `make flash-assets JFLASH_EXE=...` if installed
# elsewhere (or set the env var globally).
JFLASH_EXE     ?= /mnt/c/Program Files/SEGGER/JLink_V934b/JFlash.exe

pack-assets: $(ASSETS_BIN)

$(ASSETS_BIN): Tools/pack_assets.py $(ASSETS_CFG) $(ASSETS_LV_CONF) $(ASSETS_SRCS) | $(BUILD_DIR)
	@cd Tools && uv run pack_assets.py \
	    --config   "../$(ASSETS_CFG)" \
	    --lv-conf  "../$(ASSETS_LV_CONF)" \
	    --image-dir "../$(ASSETS_DIR)" \
	    --output   "../$@"

flash-assets: $(ASSETS_BIN)
	@PRJ=$$(wslpath -w "$(JFLASH_PRJ)" 2>/dev/null || echo "$(JFLASH_PRJ)"); \
	 BIN=$$(wslpath -w "$<"            2>/dev/null || echo "$<"); \
	 echo "  JFlash: program $$BIN @ 0x90000000 via $$PRJ"; \
	 "$(JFLASH_EXE)" -openprj"$$PRJ" -open"$$BIN",0x90000000 -auto -exit

#######################################
# clean up
#######################################
clean:
	-$(RM_DIR)

.PHONY: all build-core clean mem-report pack-assets flash-assets ota-image

#######################################
# dependencies
#######################################
-include $(wildcard $(BUILD_DIR)/*.d)

