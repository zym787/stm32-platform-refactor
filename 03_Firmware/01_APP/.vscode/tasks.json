{
    // tasks.json版本号
    "version": "2.0.0",
    "tasks": [
        {
            "type": "shell",
            "label": "build",
            "command": "make",
            "windows": {
                "args": [
                    "-j",
                    "16"
                ]
            },
            "problemMatcher": [
                "$gcc"
            ],
            "group": {
                "kind": "build"
            }
        },
        {
            "type": "shell",
            "label": "clean",
            "command": "make",
            "args": [
                "clean"
            ],
            "problemMatcher": [
                "$gcc"
            ],
            "group": {
                "kind": "build"
            }
        },
        {
            "label": "rebuild",
            "dependsOn": [
                "clean",
                "build"
            ],
            "dependsOrder": "sequence",
            "problemMatcher": [],
            "group": {
                "kind": "build"
            }
        },
        {
            // One-shot: parallel build (with mem-report) first via dependsOn,
            // then `make download` flashes the fresh hex (-auto, window stays open).
            "type": "shell",
            "label": "download",
            "command": "make",
            "args": [
                "download"
            ],
            "dependsOn": [
                "build"
            ],
            "problemMatcher": [
                "$gcc"
            ],
            "group": {
                "kind": "build"
            }
        },
        {
            // Same as download but forces a clean rebuild first.
            "type": "shell",
            "label": "rebuild & download",
            "command": "make",
            "args": [
                "download"
            ],
            "dependsOn": [
                "rebuild"
            ],
            "problemMatcher": [
                "$gcc"
            ]
        }
    ]
}